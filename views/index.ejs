<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DNS Provider Detector</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f4f6fb; }
    .container { max-width: 520px; margin-top: 60px; }
    .card {
      box-shadow: 0 2px 16px rgba(44, 62, 80, 0.10);
      border: none;
      background: #fff;
      border-radius: 18px;
    }
    .form-label { font-weight: 600; color: #34495e; }
    .result-box { margin-top: 20px; }
    h2 { color: #2d3a4b; }
    h5, h6 { color: #1a73e8; }
    .btn-primary { background: #1a73e8; border: none; }
    .btn-primary:hover { background: #155ab6; }
    .btn-success { background: #00b894; border: none; }
    .btn-success:hover { background: #019874; }
    .list-group-item {
      background: #f8fafc;
      border: 1px solid #e3e6ed;
      border-radius: 8px;
      margin-bottom: 6px;
      color: #2d3a4b;
    }
    .alert-danger { background: #ffeaea; color: #c0392b; border: none; }
    footer { color: #b2bec3; }
    .nameservers-bg {
      background: #d4f8e8 !important;
      border: 1px solid #00b894 !important;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card p-4">
      <h2 class="mb-4 text-center">DNS Provider Detector</h2>
      <form method="POST" action="/detect">
        <div class="mb-3">
          <label for="domain" class="form-label">Enter Domain Name</label>
          <input type="text" class="form-control" id="domain" name="domain" placeholder="e.g. example.com" value="<%= domain %>" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Detect Provider</button>
      </form>
      <div class="result-box">
        <% if (provider && !error) { %>
          <div class="mt-4">
            <h5>Provider: <%= provider %></h5>
            <% if (nameservers && nameservers.length) { %>
              <h6>Nameservers:</h6>
              <ul class="list-group mb-3 nameservers-bg">
                <% nameservers.forEach(function(ns) { %>
                  <li class="list-group-item nameservers-bg"><%= ns %></li>
                <% }); %>
              </ul>
            <% } %>
            <button type="button" class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#providerPortalModal">Open <%= provider %> Portal</button>
            <!-- Modal -->
            <div class="modal fade" id="providerPortalModal" tabindex="-1" aria-labelledby="providerPortalModalLabel" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="providerPortalModalLabel"><%= provider %> Portal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <p>For security reasons, <strong><%= provider %></strong> does not allow their dashboard to be embedded. Please click the button below to open the portal in a new tab.</p>
                    <a class="btn btn-primary" href="<%= provider === 'Cloudflare' ? 'https://dash.cloudflare.com/login' : provider === 'GoDaddy' ? 'https://sso.godaddy.com/?realm=idp&path=/products&app=dashboard' : provider === 'Namecheap' ? 'https://www.namecheap.com/myaccount/login/' : '#' %>" target="_blank" rel="noopener">Open <%= provider %> Portal</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4">
            <h6>Required CNAME Records</h6>
            <ul class="list-group mb-3">
              <li class="list-group-item">
                <strong>Name:</strong> www<br>
                <strong>Type:</strong> CNAME<br>
                <strong>Target:</strong> shop.hyperzod.app<br>
                <span class="text-muted">(Proxy should be temporarily disabled)</span>
              </li>
              <li class="list-group-item">
                <strong>Name:</strong> @<br>
                <strong>Type:</strong> CNAME<br>
                <strong>Target:</strong> shop.hyperzod.app
              </li>
              <li class="list-group-item">
                <strong>Name:</strong> admin.<%= domain %><br>
                <strong>Type:</strong> CNAME<br>
                <strong>Target:</strong> t.hyperzod.app
              </li>
            </ul>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger mt-3" role="alert">
            <%= error %>
          </div>
        <% } %>
      </div>
    </div>
    <footer class="text-center mt-4 text-muted" style="font-size:0.95em;">&copy; <%= new Date().getFullYear() %> DNS Provider Detector</footer>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>